FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for caching
COPY requirements_cim.txt .
RUN pip install --no-cache-dir -r requirements_cim.txt

# Copy application
COPY . .

# Install cimpy from local library
RUN pip install -e ./libraries/cimpy_3

# Set Python path
ENV PYTHONPATH="/app:/app/src:${PYTHONPATH}"

# Verify cimpy installation
RUN python -c "import cimpy; print(f'Successfully imported cimpy from {cimpy.__file__}')"

# Set environment variables
ENV FLASK_APP=app:app
ENV FLASK_ENV=production
ENV PORT=5003

EXPOSE 5003

CMD ["python", "app.py"]